import java.util.*;
public class CountingValleys {
	public static void main(String args[]) {
		Scanner sc= new Scanner(System.in);
		//sc.nextLine();
		String s=sc.nextLine();
		int sum=0,count=0;;
		for(int i=0;i<s.length();i++) {
			char ch=s.charAt(i);
			if(ch=='U') {
				sum=sum+1;
			}
			else {
				sum=sum-1;
			}
			if(sum==-1) {
				count++;
			}
		}
		System.out.println(count);
	sc.close();
	}
}
