import java.util.Scanner;
public class BirthdayCakeCandles {
		public static void main(String args[]) {
			Scanner sc= new Scanner(System.in);
			int n=sc.nextInt();
			int max=1,temp=0,count=0;
			for(int i=0;i<n;i++) {
				temp=sc.nextInt();
				if(temp>max) {
					max=temp;
					count=1;
				}
				else if(temp==max) {
					count++;
				}
			}
			System.out.println(count);
		sc.close();
	}
}
